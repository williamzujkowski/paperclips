{
  "name": "universal-paperclips",
  "version": "2.0.0",
  "description": "Universal Paperclips - An incremental game by Frank Lantz and Bennett Foddy",
  "main": "src/index.js",
  "scripts": {
    "dev": "node scripts/serve.js",
    "build": "node scripts/build.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.{js,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,html,css}\"",
    "serve:legacy": "cd docs && python3 -m http.server 8000",
    "pre-commit": "lint-staged",
    "prepare": "husky install",
    "version:bump": "node scripts/version.js bump",
    "version:list": "node scripts/version.js list",
    "version:current": "node scripts/version.js current",
    "lighthouse": "node scripts/lighthouse.js"
  },
  "keywords": [
    "game",
    "incremental",
    "paperclips",
    "javascript"
  ],
  "author": "Frank Lantz and Bennett Foddy",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jest": "^27.4.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^14.0.1",
    "prettier": "^3.0.3",
    "rollup": "^3.29.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,css}": [
      "prettier --write"
    ]
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamzujkowski/paperclips.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/williamzujkowski/paperclips/issues"
  },
  "homepage": "https://github.com/williamzujkowski/paperclips#readme"
}
